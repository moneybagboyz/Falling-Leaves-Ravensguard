{
  "$schema": "../schemas/body_zone.schema.json",
  "id": "head",
  "name": "Head",
  "hit_weight": 0.10,
  "wound_thresholds": { "graze": 2, "wound": 5, "severe": 10, "lethal": 18 },
  "critical_effects": [
    { "at_severity": "wound",  "effect": "vision_impaired" },
    { "at_severity": "severe", "effect": "knockout" },
    { "at_severity": "lethal", "effect": "death" }
  ],
  "pain_multiplier": 2.0,
  "blocks_reach_if_wounded": false,
  "tissue_layers": [
    { "type": "skin",   "yield_strength": 0.02, "thickness_mm":  2, "blunt_factor": 0.90 },
    { "type": "fat",    "yield_strength": 0.02, "thickness_mm":  5, "blunt_factor": 0.85 },
    { "type": "muscle", "yield_strength": 0.04, "thickness_mm":  8, "blunt_factor": 0.70 },
    { "type": "bone",   "yield_strength": 0.20, "thickness_mm":  8, "blunt_factor": 0.20, "fracture_threshold": 5.0 },
    { "type": "organ",  "yield_strength": 0.01, "thickness_mm": 50, "blunt_factor": 0.00, "organ_id": "brain", "vital": true }
  ]
}
