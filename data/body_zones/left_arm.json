{
  "$schema": "../schemas/body_zone.schema.json",
  "id": "left_arm",
  "name": "Left Arm",
  "hit_weight": 0.10,
  "wound_thresholds": { "graze": 2, "wound": 5, "severe": 10, "lethal": 16 },
  "critical_effects": [
    { "at_severity": "severe", "effect": "mobility_halved" },
    { "at_severity": "lethal", "effect": "limb_lost" }
  ],
  "pain_multiplier": 0.8,
  "blocks_reach_if_wounded": true,
  "tissue_layers": [
    { "type": "skin",   "yield_strength": 0.02, "thickness_mm":  2, "blunt_factor": 0.90 },
    { "type": "fat",    "yield_strength": 0.02, "thickness_mm":  8, "blunt_factor": 0.85 },
    { "type": "muscle", "yield_strength": 0.04, "thickness_mm": 20, "blunt_factor": 0.70 },
    { "type": "bone",   "yield_strength": 0.20, "thickness_mm":  8, "blunt_factor": 0.20, "fracture_threshold": 3.5 }
  ]
}
