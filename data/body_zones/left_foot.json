{
  "$schema": "../schemas/body_zone.schema.json",
  "id": "left_foot",
  "name": "Left Foot",
  "hit_weight": 0.02,
  "wound_thresholds": { "graze": 1, "wound": 3, "severe": 8, "lethal": 13 },
  "critical_effects": [
    { "at_severity": "wound",  "effect": "speed_reduced" },
    { "at_severity": "severe", "effect": "mobility_halved" },
    { "at_severity": "lethal", "effect": "limb_lost" }
  ],
  "pain_multiplier": 1.0,
  "blocks_reach_if_wounded": false,
  "tissue_layers": [
    { "type": "skin",   "yield_strength": 0.02, "thickness_mm":  2, "blunt_factor": 0.90 },
    { "type": "fat",    "yield_strength": 0.02, "thickness_mm":  5, "blunt_factor": 0.85 },
    { "type": "muscle", "yield_strength": 0.04, "thickness_mm":  6, "blunt_factor": 0.70 },
    { "type": "bone",   "yield_strength": 0.20, "thickness_mm":  5, "blunt_factor": 0.20, "fracture_threshold": 2.5 }
  ]
}
