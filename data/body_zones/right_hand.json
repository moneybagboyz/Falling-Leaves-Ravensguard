{
  "$schema": "../schemas/body_zone.schema.json",
  "id": "right_hand",
  "name": "Right Hand",
  "hit_weight": 0.03,
  "wound_thresholds": { "graze": 1, "wound": 3, "severe": 7, "lethal": 12 },
  "critical_effects": [
    { "at_severity": "severe", "effect": "grip_lost" },
    { "at_severity": "lethal", "effect": "limb_lost" }
  ],
  "pain_multiplier": 1.1,
  "blocks_reach_if_wounded": true,
  "tissue_layers": [
    { "type": "skin",   "yield_strength": 0.02, "thickness_mm":  2, "blunt_factor": 0.90 },
    { "type": "fat",    "yield_strength": 0.02, "thickness_mm":  3, "blunt_factor": 0.85 },
    { "type": "muscle", "yield_strength": 0.04, "thickness_mm":  5, "blunt_factor": 0.70 },
    { "type": "bone",   "yield_strength": 0.20, "thickness_mm":  4, "blunt_factor": 0.20, "fracture_threshold": 2.0 }
  ]
}
