{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BodyZone",
  "description": "Definition of a single targetable body zone for combat damage resolution.",
  "type": "object",
  "required": ["id", "name", "hit_weight", "wound_thresholds"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "id": {
      "type": "string",
      "description": "Unique zone identifier. e.g. 'head', 'chest', 'left_arm'."
    },
    "name": {
      "type": "string",
      "description": "Display name."
    },
    "hit_weight": {
      "type": "number",
      "minimum": 0,
      "description": "Relative probability of being hit. All zones in a body sum to 1.0 when normalised."
    },
    "wound_thresholds": {
      "type": "object",
      "description": "Damage values (post-mitigation) that trigger each wound severity level.",
      "required": ["graze", "wound", "severe", "lethal"],
      "additionalProperties": false,
      "properties": {
        "graze":  { "type": "number", "minimum": 0 },
        "wound":  { "type": "number", "minimum": 0 },
        "severe": { "type": "number", "minimum": 0 },
        "lethal": { "type": "number", "minimum": 0 }
      }
    },
    "critical_effects": {
      "type": "array",
      "description": "Special effects triggered at or above 'severe' wound on this zone.",
      "items": {
        "type": "object",
        "required": ["at_severity", "effect"],
        "properties": {
          "at_severity": {
            "type": "string",
            "enum": ["graze", "wound", "severe", "lethal"]
          },
          "effect": {
            "type": "string",
            "description": "Effect tag. e.g. 'knockout', 'bleed_heavy', 'mobility_halved', 'death'."
          }
        }
      }
    },
    "pain_multiplier": {
      "type": "number",
      "minimum": 0,
      "default": 1.0,
      "description": "Multiplier applied to pain generated by wounds on this zone."
    },
    "blocks_reach_if_wounded": {
      "type": "boolean",
      "default": false,
      "description": "If true, a wound of severity >= 'wound' disables use of items held in this limb."
    }
  }
}
